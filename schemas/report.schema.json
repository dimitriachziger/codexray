{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/dimitriachziger/codexray/main/schemas/report.schema.json",
  "title": "Codex Token Analyzer Report",
  "description": "The public JSON contract for single- and multi-session Codexray reports.",
  "oneOf": [
    {
      "$ref": "#/$defs/sessionReport"
    },
    {
      "$ref": "#/$defs/multiSessionReport"
    }
  ],
  "$defs": {
    "nonNegativeInteger": {
      "type": "integer",
      "minimum": 0
    },
    "confidence": {
      "enum": [
        "high",
        "medium",
        "low"
      ]
    },
    "itemCategory": {
      "enum": [
        "instructions",
        "user",
        "assistant",
        "tool_call",
        "tool_output"
      ]
    },
    "tokenUsage": {
      "type": "object",
      "required": [
        "input_tokens",
        "cached_input_tokens",
        "cache_write_input_tokens",
        "output_tokens",
        "reasoning_output_tokens",
        "total_tokens"
      ],
      "properties": {
        "input_tokens": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "cached_input_tokens": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "cache_write_input_tokens": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "output_tokens": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "reasoning_output_tokens": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "total_tokens": {
          "$ref": "#/$defs/nonNegativeInteger"
        }
      },
      "additionalProperties": false
    },
    "accounting": {
      "type": "object",
      "required": [
        "input_tokens",
        "cached_input_tokens",
        "cache_write_input_tokens",
        "output_tokens",
        "reasoning_output_tokens",
        "total_tokens",
        "model_steps",
        "turns"
      ],
      "properties": {
        "input_tokens": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "cached_input_tokens": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "cache_write_input_tokens": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "output_tokens": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "reasoning_output_tokens": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "total_tokens": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "model_steps": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "turns": {
          "$ref": "#/$defs/nonNegativeInteger"
        }
      },
      "additionalProperties": false
    },
    "categoryTokens": {
      "type": "object",
      "required": [
        "instructions",
        "user",
        "assistant",
        "tool_call",
        "tool_output"
      ],
      "properties": {
        "instructions": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "user": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "assistant": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "tool_call": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "tool_output": {
          "$ref": "#/$defs/nonNegativeInteger"
        }
      },
      "additionalProperties": false
    },
    "modelStep": {
      "type": "object",
      "required": [
        "index",
        "turn_id",
        "model",
        "accounting",
        "visible_tokens",
        "visible_by_category",
        "unattributed_input_tokens",
        "visible_overage_tokens",
        "coverage_ratio",
        "reconstruction_confidence"
      ],
      "properties": {
        "index": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "turn_id": {
          "type": "string"
        },
        "model": {
          "type": "string"
        },
        "accounting": {
          "$ref": "#/$defs/tokenUsage"
        },
        "visible_tokens": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "visible_by_category": {
          "$ref": "#/$defs/categoryTokens"
        },
        "unattributed_input_tokens": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "visible_overage_tokens": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "coverage_ratio": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "reconstruction_confidence": {
          "$ref": "#/$defs/confidence"
        }
      },
      "additionalProperties": false
    },
    "turn": {
      "type": "object",
      "required": [
        "id",
        "model",
        "model_steps"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "model": {
          "type": "string"
        },
        "model_steps": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/modelStep"
          }
        }
      },
      "additionalProperties": false
    },
    "coverage": {
      "type": "object",
      "required": [
        "estimated_visible_input_tokens",
        "unattributed_input_tokens",
        "visible_overage_tokens",
        "ratio",
        "reconstruction_confidence",
        "encoding",
        "encoding_fallback"
      ],
      "properties": {
        "estimated_visible_input_tokens": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "unattributed_input_tokens": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "visible_overage_tokens": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "ratio": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "reconstruction_confidence": {
          "$ref": "#/$defs/confidence"
        },
        "encoding": {
          "type": "string"
        },
        "encoding_fallback": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "sessionMetadata": {
      "type": "object",
      "required": [
        "id",
        "rollout_file",
        "turns",
        "model_steps"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "cli_version": {
          "type": "string"
        },
        "cwd": {
          "type": "string"
        },
        "rollout_file": {
          "type": "string"
        },
        "turns": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "model_steps": {
          "$ref": "#/$defs/nonNegativeInteger"
        }
      },
      "additionalProperties": false
    },
    "publicItem": {
      "type": "object",
      "required": [
        "id",
        "category",
        "estimated_tokens",
        "retained_steps",
        "retained_context_load"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "category": {
          "$ref": "#/$defs/itemCategory"
        },
        "estimated_tokens": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "retained_steps": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "retained_context_load": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "turn_id": {
          "type": "string"
        },
        "target": {
          "type": "string"
        },
        "snippet": {
          "type": "string",
          "maxLength": 160
        }
      },
      "additionalProperties": false
    },
    "findingEvidence": {
      "type": "object",
      "properties": {
        "occurrences": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "target": {
          "type": "string"
        },
        "estimated_tokens_each": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/nonNegativeInteger"
          }
        },
        "estimated_avoidable_context_load": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "overlap_ratio": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "mutation_between_reads": {
          "type": "boolean"
        },
        "snippet": {
          "type": "string",
          "maxLength": 160
        }
      },
      "additionalProperties": false
    },
    "finding": {
      "type": "object",
      "required": [
        "id",
        "kind",
        "severity",
        "confidence",
        "evidence",
        "message"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "kind": {
          "enum": [
            "duplicate_output",
            "similar_output",
            "large_output"
          ]
        },
        "severity": {
          "enum": [
            "info",
            "warning"
          ]
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        },
        "evidence": {
          "$ref": "#/$defs/findingEvidence"
        },
        "message": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "recommendation": {
      "type": "object",
      "required": [
        "id",
        "kind",
        "confidence",
        "evidence",
        "estimated_avoidable_context_load",
        "message"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "kind": {
          "enum": [
            "workflow",
            "agents_rule_candidate"
          ]
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        },
        "evidence": {
          "type": "string"
        },
        "estimated_avoidable_context_load": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "message": {
          "type": "string"
        },
        "session_count": {
          "$ref": "#/$defs/nonNegativeInteger"
        }
      },
      "additionalProperties": false
    },
    "warning": {
      "type": "object",
      "required": [
        "code",
        "message"
      ],
      "properties": {
        "code": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "line": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": false
    },
    "sessionReport": {
      "type": "object",
      "required": [
        "schema_version",
        "session",
        "accounting",
        "coverage",
        "turns",
        "top_retained_context",
        "findings",
        "recommendations",
        "warnings"
      ],
      "properties": {
        "schema_version": {
          "const": "1.0.0"
        },
        "session": {
          "$ref": "#/$defs/sessionMetadata"
        },
        "accounting": {
          "$ref": "#/$defs/accounting"
        },
        "coverage": {
          "$ref": "#/$defs/coverage"
        },
        "turns": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/turn"
          }
        },
        "top_retained_context": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/publicItem"
          }
        },
        "findings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/finding"
          }
        },
        "recommendations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/recommendation"
          }
        },
        "warnings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/warning"
          }
        }
      },
      "additionalProperties": false
    },
    "multiSessionReport": {
      "type": "object",
      "required": [
        "schema_version",
        "generated_at",
        "session_count",
        "accounting",
        "coverage",
        "findings",
        "recommendations",
        "warnings",
        "sessions"
      ],
      "properties": {
        "schema_version": {
          "const": "1.0.0"
        },
        "generated_at": {
          "type": "string",
          "format": "date-time"
        },
        "session_count": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "accounting": {
          "$ref": "#/$defs/accounting"
        },
        "coverage": {
          "$ref": "#/$defs/coverage"
        },
        "findings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/finding"
          }
        },
        "recommendations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/recommendation"
          }
        },
        "warnings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/warning"
          }
        },
        "sessions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/sessionReport"
          }
        }
      },
      "additionalProperties": false
    }
  }
}
